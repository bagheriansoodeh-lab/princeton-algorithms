import edu.princeton.cs.algs4.Point2D;
import edu.princeton.cs.algs4.RectHV;
import edu.princeton.cs.algs4.StdDraw;
import java.util.ArrayList;

public class KdTree {

    private Node root;
    private int size;

    private static class Node {
        final Point2D point;
        final RectHV rect;   // rectangle this node's subtree is responsible for
        Node left, right;

        Node(Point2D point, RectHV rect) {
            this.point = point;
            this.rect  = rect;
        }
    }

    public KdTree() {
        root = null;
        size = 0;
    }

    public boolean isEmpty() {
        return size == 0;
    }

    public int size() {
        return size;
    }

    public void insert(Point2D p) {
        if (p == null) throw new IllegalArgumentException("Point is null");
        root = insert(root, p, true, new RectHV(0, 0, 1, 1));
    }

    private Node insert(Node node, Point2D p, boolean vertical, RectHV rect) {
        if (node == null) { size++; return new Node(p, rect); }
        if (node.point.equals(p)) return node; // duplicate

        boolean goLeft;
        if (vertical) goLeft = p.x() < node.point.x();
        else          goLeft = p.y() < node.point.y();

        if (goLeft) {
            RectHV childRect = vertical
                ? new RectHV(rect.xmin(), rect.ymin(), node.point.x(), rect.ymax())
                : new RectHV(rect.xmin(), rect.ymin(), rect.xmax(), node.point.y());
            node.left  = insert(node.left,  p, !vertical, childRect);
        } else {
            RectHV childRect = vertical
                ? new RectHV(node.point.x(), rect.ymin(), rect.xmax(), rect.ymax())
                : new RectHV(rect.xmin(), node.point.y(), rect.xmax(), rect.ymax());
            node.right = insert(node.right, p, !vertical, childRect);
        }
        return node;
    }

    public boolean contains(Point2D p) {
        if (p == null) throw new IllegalArgumentException("Point is null");
        return contains(root, p, true);
    }

    private boolean contains(Node node, Point2D p, boolean vertical) {
        if (node == null) return false;
        if (node.point.equals(p)) return true;

        boolean goLeft;
        if (vertical) goLeft = p.x() < node.point.x();
        else          goLeft = p.y() < node.point.y();

        if (goLeft) return contains(node.left,  p, !vertical);
        else        return contains(node.right, p, !vertical);
    }

    public void draw() {
        draw(root, true);
    }

    private void draw(Node node, boolean vertical) {
        if (node == null) return;

        // Draw point
        StdDraw.setPenColor(StdDraw.BLACK);
        StdDraw.setPenRadius(0.01);
        node.point.draw();

        // Draw splitting line
        StdDraw.setPenRadius(0.002);
        if (vertical) {
            StdDraw.setPenColor(StdDraw.RED);
            StdDraw.line(node.point.x(), node.rect.ymin(), node.point.x(), node.rect.ymax());
        } else {
            StdDraw.setPenColor(StdDraw.BLUE);
            StdDraw.line(node.rect.xmin(), node.point.y(), node.rect.xmax(), node.point.y());
        }

        draw(node.left,  !vertical);
        draw(node.right, !vertical);
    }

    public Iterable<Point2D> range(RectHV rect) {
        if (rect == null) throw new IllegalArgumentException("Rectangle is null");
        ArrayList<Point2D> result = new ArrayList<>();
        range(root, rect, result);
        return result;
    }

    private void range(Node node, RectHV rect, ArrayList<Point2D> result) {
        if (node == null) return;
        if (!rect.intersects(node.rect)) return; // pruning
        if (rect.contains(node.point)) result.add(node.point);
        range(node.left,  rect, result);
        range(node.right, rect, result);
    }

    public Point2D nearest(Point2D p) {
        if (p == null) throw new IllegalArgumentException("Point is null");
        if (isEmpty()) return null;
        return nearest(root, p, root.point, true);
    }

    private Point2D nearest(Node node, Point2D query, Point2D best, boolean vertical) {
        if (node == null) return best;
        // Pruning: if the rectangle is farther than current best, skip
        if (node.rect.distanceSquaredTo(query) >= query.distanceSquaredTo(best)) return best;

        if (node.point.distanceSquaredTo(query) < best.distanceSquaredTo(query))
            best = node.point;

        // Choose which subtree to explore first (the one on the same side as query)
        boolean goLeftFirst;
        if (vertical) goLeftFirst = query.x() < node.point.x();
        else          goLeftFirst = query.y() < node.point.y();

        if (goLeftFirst) {
            best = nearest(node.left,  query, best, !vertical);
            best = nearest(node.right, query, best, !vertical);
        } else {
            best = nearest(node.right, query, best, !vertical);
            best = nearest(node.left,  query, best, !vertical);
        }
        return best;
    }

    public static void main(String[] args) {
        KdTree kd = new KdTree();
        kd.insert(new Point2D(0.7, 0.2));
        kd.insert(new Point2D(0.5, 0.4));
        kd.insert(new Point2D(0.2, 0.3));
        kd.insert(new Point2D(0.4, 0.7));
        kd.insert(new Point2D(0.9, 0.6));
        System.out.println("size: " + kd.size());
        System.out.println("contains (0.5,0.4): " + kd.contains(new Point2D(0.5, 0.4)));
        System.out.println("contains (0.1,0.1): " + kd.contains(new Point2D(0.1, 0.1)));
        System.out.println("nearest to (0.5,0.5): " + kd.nearest(new Point2D(0.5, 0.5)));
        System.out.println("range [0.1,0.6]x[0.1,0.6]:");
        for (Point2D p : kd.range(new RectHV(0.1, 0.1, 0.6, 0.6))) System.out.println("  " + p);
    }
}
